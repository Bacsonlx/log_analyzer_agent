{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "mcp__log-analyzer",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(ls *)",
      "Bash(wc *)",
      "Bash(file *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(git status *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(git rev-parse *)",
      "Bash(git remote *)",
      "Bash(git tag *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git check-ignore *)",
      "Bash(lsof -ti:8080 -ti:3000 -ti:5173 -ti:4173 -ti:8000)",
      "Bash(lsof -ti:8080)",
      "Bash(xargs kill:*)",
      "Bash(python3 -m json.tool)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=$(git rev-parse --show-toplevel) && file_path=$(cat | jq -r '.tool_input.file_path // .tool_input.path // empty') && [ -n \"$file_path\" ] && bash \"$ROOT/cursor/hooks/check-api-boundary.sh\" \"$file_path\" || true"
          }
        ]
      }
    ]
  }
}
