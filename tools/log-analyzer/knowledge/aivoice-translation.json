  "common_causes": [
    {
      "pattern": "ASRTimeout.*using the last updated result",
      "cause": "ASR 超时，使用最后更新的结果（可能网络延迟或音频流中断）"
    },
    {
      "pattern": "Unsupported audio format",
      "cause": "不支持的音频格式（错误码 10071）"
    },
    {
      "pattern": "Unsupported audio source type",
      "cause": "不支持的音频源类型"
    },
    {
      "pattern": "ThingAudioRecordLanguageError",
      "cause": "语言设置错误（错误码 10003）"
    },
    {
      "pattern": "Create multiple input sources CoderFailed",
      "cause": "多输入源编码器创建失败（PhoneAndBuds 模式）"
    },
    {
      "pattern": "multiSourceCoder Not initialized",
      "cause": "多源编码器未初始化（PhoneAndBuds 模式）"
    },
    {
      "pattern": "Switch.*Failed|dpReply.*Timeout",
      "cause": "SI 模式切换失败或 dp 回复超时"
    },
    {
      "pattern": "Simultaneous interpretation dp.*Failed",
      "cause": "SI 同传 dp 下发失败"
    },
    {
      "pattern": "no audio stream within 3 seconds",
      "cause": "3 秒内无音频流，电话翻译认为通话已断开"
    },
    {
      "pattern": "ThingAudioTranslateTTSUrlError",
      "cause": "TTS URL 错误（错误码 10101）"
    }
  ],
  "normal_behaviors": [
    {
      "pattern": "Save last time ASRResult",
      "description": "保存最后一次 ASR 结果，任务结束时的正常行为",
      "how_to_identify": "出现在 task stopped/completed 之前"
    },
    {
      "pattern": "The recording duration has reached the limit",
      "description": "录音时长达到上限，系统自动停止并重新开始",
      "how_to_identify": "之后紧跟自动重新开始或结束录音"
    },
    {
      "pattern": "VADMaximum length truncation",
      "description": "VAD 最大长度截断，为防止单次说话过长的正常限制",
      "how_to_identify": "截断后继续正常识别"
    }
  ],
